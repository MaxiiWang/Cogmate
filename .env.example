# Brain Agent 环境配置
# 复制此文件为 .env 并修改配置

# ===== 数据库配置（必需）=====

# Neo4j 图数据库
BRAIN_NEO4J_URI=bolt://localhost:7687
BRAIN_NEO4J_USER=neo4j
BRAIN_NEO4J_PASSWORD=your_secure_password_here  # 请修改！

# Qdrant 向量数据库
BRAIN_QDRANT_HOST=localhost
BRAIN_QDRANT_PORT=6333
BRAIN_COLLECTION_NAME=facts

# ===== LLM 配置（可选）=====
# 用于抽象层生成、挑战机制、智能回答

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI（备选）
# OPENAI_API_KEY=sk-xxx

# ===== 可视化配置（可选）=====

# 可视化服务公开 URL（用于生成分享链接）
VISUAL_PUBLIC_URL=http://localhost:8000

# Token 默认有效期
TOKEN_DEFAULT_DURATION=7d

# ===== 高级配置 =====

# 向量模型（默认 BGE-M3）
# EMBEDDING_MODEL=BAAI/bge-m3

# 向量维度
# EMBEDDING_DIM=1024

# 日志级别
# LOG_LEVEL=INFO

# SQLite 数据库路径（相对于项目根目录）
# SQLITE_PATH=data/brain.db
